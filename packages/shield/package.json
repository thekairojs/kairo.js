{
  "name": "@thekairojs/kairo-shield",
  "version": "1.0.1",
  "description": "KAIRO Data Shield — PII detection and redaction for outbound responses",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@thekairojs/kairo": "*"
  },
  "devDependencies": {
    "kairo": "*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thekairojs/kairo.js"
  }
}
