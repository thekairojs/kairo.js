{
  "name": "@thekairojs/kairo-cli",
  "version": "1.0.0",
  "description": "KAIRO CLI — project scaffolding, route inspection, and security audit",
  "type": "module",
  "bin": {
    "@thekairojs/kairo": "./dist/bin.js"
  },
  "main": "./dist/bin.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev":   "tsup --watch",
    "test":  "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup":    "*",
    "vitest": "^4.1.7",
    "typescript": "*"
  }
}
