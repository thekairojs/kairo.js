{
  "name": "@thekairojs/kairo-adapter-uws",
  "version": "1.0.0",
  "description": "uWebSockets.js adapter for KAIRO — drop-in replacement for the default node:http server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@thekairojs/kairo": "*"
  },
  "peerDependencies": {},
  "keywords": ["kairo", "uwebsockets", "uws", "adapter", "server", "performance"],
  "license": "MIT",
  "engines": { "node": ">=20.0.0" },
  "repository": { "type": "git", "url": "https://github.com/thekairojs/kairo.js" }
}
