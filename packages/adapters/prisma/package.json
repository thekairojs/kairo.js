{
  "name": "@thekairojs/kairo-adapter-prisma",
  "version": "1.0.0",
  "description": "Prisma adapter for KAIRO — entropy gating, canary injection, and PII scanning on every query",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@thekairojs/kairo": "*",
    "@thekairojs/kairo-sentinel": "*"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": { "optional": false }
  },
  "keywords": ["kairo", "prisma", "adapter", "security", "canary"],
  "license": "MIT",
  "engines": { "node": ">=20.0.0" },
  "repository": { "type": "git", "url": "https://github.com/thekairojs/kairo.js" }
}
