{
  "name": "kairo-hardening",
  "version": "1.0.0",
  "description": "KAIRO Hardening Layer — active entropy-based request blocking",
  "type": "module",
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build":     "tsup",
    "dev":       "tsup --watch",
    "test":      "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "kairo": "*"
  },
  "devDependencies": {
    "kairo":      "*",
    "tsup":       "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
