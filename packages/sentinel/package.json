{
  "name": "kairo-sentinel",
  "version": "1.0.0",
  "description": "KAIRO Runtime Sentinel — sink checking, memory monitoring, canary records",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "kairo": "*"
  },
  "devDependencies": {
    "kairo": "*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
